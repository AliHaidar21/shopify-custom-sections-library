{{ 'stock-urgency-bar.css' | asset_url | stylesheet_tag }}

<section
  class="stock-urgency-bar stock-urgency-bar--{{ section.id }} {% if section.settings.show_stripes %}stock-urgency-bar--striped{% endif %} {% if section.settings.animate_stripes %}stock-urgency-bar--animate-stripes{% endif %}"
  data-stock-urgency-bar
  data-target-percent="{{ section.settings.stock_percent }}"
  data-animate-fill="{{ section.settings.animate_fill }}"
  style="
    --sub-section-bg: {{ section.settings.section_background }};
    --sub-heading-color: {{ section.settings.heading_color }};
    --sub-track-color: {{ section.settings.track_color }};
    --sub-fill-color: {{ section.settings.fill_color }};
    --sub-stripe-color: {{ section.settings.stripe_color }};
    --sub-target-percent: {{ section.settings.stock_percent }}%;
    --sub-max-width: {{ section.settings.max_width }}px;
    --sub-bar-height: {{ section.settings.bar_height }}px;
    --sub-radius: {{ section.settings.border_radius }}px;
    --sub-padding-top: {{ section.settings.padding_top }}px;
    --sub-padding-bottom: {{ section.settings.padding_bottom }}px;
    --sub-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --sub-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
  "
>
  <div class="stock-urgency-bar__inner">
    {% if section.settings.heading != blank %}
      <h2 class="stock-urgency-bar__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div
      class="stock-urgency-bar__track"
      role="progressbar"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="{{ section.settings.stock_percent }}"
      aria-label="{{ section.settings.heading | escape }}"
    >
      <span class="stock-urgency-bar__fill" data-stock-urgency-fill></span>
    </div>

    {% if section.settings.show_percent_text %}
      <p class="stock-urgency-bar__percent-text">
        {{ section.settings.stock_percent }}% {{ section.settings.percent_text }}
      </p>
    {% endif %}
  </div>
</section>

<script src="{{ 'stock-urgency-bar.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Stock urgency bar",
  "tag": "section",
  "class": "section-stock-urgency-bar",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Selling Fast-Low Stock!"
    },
    {
      "type": "range",
      "id": "stock_percent",
      "label": "Filled stock amount",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 22
    },
    {
      "type": "checkbox",
      "id": "show_percent_text",
      "label": "Show percent text under bar",
      "default": false
    },
    {
      "type": "text",
      "id": "percent_text",
      "label": "Percent text",
      "default": "remaining"
    },
    {
      "type": "header",
      "content": "Bar style"
    },
    {
      "type": "checkbox",
      "id": "show_stripes",
      "label": "Show diagonal stripes",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "animate_stripes",
      "label": "Animate stripes",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "animate_fill",
      "label": "Animate fill on load",
      "default": true
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Bar maximum width",
      "min": 600,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1250
    },
    {
      "type": "range",
      "id": "bar_height",
      "label": "Bar height",
      "min": 12,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 26
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Rounded edges",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Text size"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size desktop",
      "min": 18,
      "max": 54,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size mobile",
      "min": 16,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 90,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 90,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#FF1F1F"
    },
    {
      "type": "color",
      "id": "track_color",
      "label": "Track color",
      "default": "#DDDDDD"
    },
    {
      "type": "color",
      "id": "fill_color",
      "label": "Fill color",
      "default": "#FF1F1F"
    },
    {
      "type": "color",
      "id": "stripe_color",
      "label": "Stripe color",
      "default": "#D91515"
    }
  ],
  "presets": [
    {
      "name": "Stock urgency bar"
    }
  ]
}
{% endschema %}
