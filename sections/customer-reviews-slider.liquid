{{ 'customer-reviews-slider.css' | asset_url | stylesheet_tag }}

{% liquid
  assign desktop_cards = section.settings.desktop_cards | plus: 0
  assign desktop_gap_total = desktop_cards | minus: 1 | times: section.settings.card_gap
%}

<section
  class="customer-reviews-slider customer-reviews-slider--{{ section.id }} {% if section.settings.show_edge_fade %}customer-reviews-slider--fade-edges{% endif %}"
  data-customer-reviews-slider
  data-autoplay="{{ section.settings.enable_autoplay }}"
  data-autoplay-interval="{{ section.settings.autoplay_interval | times: 1000 }}"
  data-pause-on-hover="{{ section.settings.pause_on_hover }}"
  style="
    --crs-bg: {{ section.settings.section_background }};
    --crs-heading: {{ section.settings.heading_color }};
    --crs-text: {{ section.settings.text_color }};
    --crs-muted: {{ section.settings.muted_text_color }};
    --crs-star-bg: {{ section.settings.star_background }};
    --crs-star-color: {{ section.settings.star_color }};
    --crs-card-bg: {{ section.settings.card_background }};
    --crs-card-shadow: {{ section.settings.card_shadow_color }};
    --crs-radius: {{ section.settings.card_radius }}px;
    --crs-gap: {{ section.settings.card_gap }}px;
    --crs-max-width: {{ section.settings.max_width }}px;
    --crs-padding-top: {{ section.settings.padding_top }}px;
    --crs-padding-bottom: {{ section.settings.padding_bottom }}px;
    --crs-card-width: calc((100% - {{ desktop_gap_total }}px) / {{ desktop_cards }});
    --crs-mobile-card-width: {{ section.settings.mobile_card_width }}vw;
  "
>
  <div class="customer-reviews-slider__inner">
    {% if section.settings.heading != blank %}
      <h2 class="customer-reviews-slider__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.show_rating_summary %}
      <div class="customer-reviews-slider__summary" aria-label="{{ section.settings.rating_accessibility_label | escape }}">
        {% if section.settings.rating_label != blank %}
          <span class="customer-reviews-slider__rating-label">
            {{ section.settings.rating_label }}
          </span>
        {% endif %}

        {% if section.settings.rating_score != blank %}
          <span class="customer-reviews-slider__rating-score">
            {{ section.settings.rating_score }}
          </span>
        {% endif %}

        <div class="customer-reviews-slider__stars" aria-hidden="true">
          {% for i in (1..5) %}
            <span class="customer-reviews-slider__star {% if i > section.settings.summary_star_count %}is-empty{% endif %}">
              <svg viewBox="0 0 24 24">
                <path fill="currentColor" d="M12 18.3l-5.71 3 1.09-6.35-4.62-4.5 6.38-.93L12 3.7l2.85 5.82 6.38.93-4.62 4.5 1.09 6.35z"></path>
              </svg>
            </span>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="customer-reviews-slider__shell">
        <div class="customer-reviews-slider__mask">
          <div class="customer-reviews-slider__track" data-reviews-track>
            {% for block in section.blocks %}
              <article class="customer-reviews-slider__card" {{ block.shopify_attributes }}>
                <div class="customer-reviews-slider__card-stars" aria-label="{{ block.settings.star_count }} out of 5 stars">
                  {% for i in (1..5) %}
                    <span class="customer-reviews-slider__star customer-reviews-slider__star--small {% if i > block.settings.star_count %}is-empty{% endif %}">
                      <svg viewBox="0 0 24 24">
                        <path fill="currentColor" d="M12 18.3l-5.71 3 1.09-6.35-4.62-4.5 6.38-.93L12 3.7l2.85 5.82 6.38.93-4.62 4.5 1.09 6.35z"></path>
                      </svg>
                    </span>
                  {% endfor %}
                </div>

                {% if block.settings.review_title != blank %}
                  <h3>{{ block.settings.review_title }}</h3>
                {% endif %}

                {% if block.settings.review_author != blank %}
                  <p>{{ block.settings.review_author }}</p>
                {% endif %}
              </article>
            {% endfor %}
          </div>
        </div>
      </div>
    {% elsif request.design_mode %}
      <div class="customer-reviews-slider__empty">
        Add review blocks to build your slider.
      </div>
    {% endif %}
  </div>
</section>

<script src="{{ 'customer-reviews-slider.js' | asset_url }}" defer></script>

{% schema %}


{
  "name": "Customer reviews slider",
  "tag": "section",
  "class": "section-customer-reviews-slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Suggested text: Our customers tell it better than we do!",
      "default": "Our customers tell it better than we do!"
    },
    {
      "type": "checkbox",
      "id": "show_rating_summary",
      "label": "Show rating summary",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_label",
      "label": "Rating label",
      "info": "Suggested text: Excellent",
      "default": "Excellent"
    },
    {
      "type": "text",
      "id": "rating_score",
      "label": "Rating score",
      "info": "Suggested text: 4.9 / 5",
      "default": "4.9 / 5"
    },
    {
      "type": "range",
      "id": "summary_star_count",
      "label": "Summary star count",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "rating_accessibility_label",
      "label": "Rating accessibility label",
      "info": "Suggested text: Customer rating summary"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Autoplay speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause autoplay on hover",
      "default": true
    },
    {
      "type": "select",
      "id": "desktop_cards",
      "label": "Cards visible on desktop",
      "default": "3",
      "options": [
        {
          "value": "2",
          "label": "2 cards"
        },
        {
          "value": "3",
          "label": "3 cards"
        },
        {
          "value": "4",
          "label": "4 cards"
        }
      ]
    },
    {
      "type": "range",
      "id": "mobile_card_width",
      "label": "Mobile card width",
      "min": 70,
      "max": 95,
      "step": 1,
      "unit": "vw",
      "default": 86
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Card gap",
      "min": 10,
      "max": 34,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card radius",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "checkbox",
      "id": "show_edge_fade",
      "label": "Show edge fade",
      "default": true
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 900,
      "max": 1800,
      "step": 100,
      "unit": "px",
      "default": 1700
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#304D6D"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Main text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "star_background",
      "label": "Star background",
      "default": "#00b67a"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_shadow_color",
      "label": "Card shadow color",
      "default": "#12263F"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "star_count",
          "label": "Star count",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Review title",
          "info": "Suggested text: Gets through my deck so much faster",
          "default": "Gets through my deck so much faster"
        },
        {
          "type": "text",
          "id": "review_author",
          "label": "Review author/details",
          "info": "Suggested text: AUB Medicine, Year 2",
          "default": "AUB Medicine, Year 2"
        }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "Customer reviews slider",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review_title": "Gets through my deck so much faster",
            "review_author": "AUB Medicine, Year 2"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_title": "Actually changed how I study for shelf exams",
            "review_author": "LAU Medicine, Year 3"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_title": "Worth every dollar, wish I got it earlier",
            "review_author": "UOB, MCAT prep"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_title": "Made Step prep feel less impossible",
            "review_author": "AUB Medicine, Step 1 prep"
          }
        }
      ]
    }
  ]
}


{% endschema %}
