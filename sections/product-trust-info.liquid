      "default": "<p>Our Hair Texturizer Powder gives your hair instant lift and natural texture in seconds. It is lightweight, mess free, and effortless to use.</p>"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 500,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 1050
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Main text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#041f60"
    },
    {
      "type": "color",
      "id": "muted_background",
      "label": "Delivery bar background",
      "default": "#f6f7f9"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Divider color",
      "default": "#e2e5ec"
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon circle background",
      "default": "#041f60"
    },
    {
      "type": "color",
