            {
              "value": "star",
              "label": "Star"
            },
            {
              "value": "check",
              "label": "Check"
            },
            {
              "value": "leaf",
              "label": "Leaf"
            },
            {
              "value": "heart",
              "label": "Heart"
            },
            {
              "value": "clock",
              "label": "Clock"
            },
            {
              "value": "package",
