{{ 'brand-comparison-table.css' | asset_url | stylesheet_tag }}

<section
  class="brand-comparison-table brand-comparison-table--{{ section.id }}"
  style="
    --bct-bg: {{ section.settings.section_background }};
    --bct-text: {{ section.settings.text_color }};
    --bct-brand-color: {{ section.settings.brand_color }};
    --bct-accent: {{ section.settings.accent_color }};
    --bct-border: {{ section.settings.border_color }};
    --bct-row-hover: {{ section.settings.row_hover_background }};
    --bct-check-bg: {{ section.settings.check_background }};
    --bct-check-text: {{ section.settings.check_text_color }};
    --bct-x-bg: {{ section.settings.x_background }};
    --bct-x-text: {{ section.settings.x_text_color }};
    --bct-max-width: {{ section.settings.max_width }}px;
    --bct-padding-top: {{ section.settings.padding_top }}px;
    --bct-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="brand-comparison-table__wrap">
    <div class="brand-comparison-table__grid brand-comparison-table__head">
      <div class="brand-comparison-table__title">
        {% if section.settings.heading_before != blank or section.settings.heading_highlight != blank %}
          <h2>
            {% if section.settings.heading_before != blank %}
              {{ section.settings.heading_before }}<br>
            {% endif %}

            {% if section.settings.heading_highlight != blank %}
              <span>{{ section.settings.heading_highlight }}</span>
            {% endif %}
          </h2>
        {% endif %}
      </div>

      <div class="brand-comparison-table__brand">
        {{ section.settings.brand_label }}
      </div>

      <div class="brand-comparison-table__others">
        {{ section.settings.others_label }}
      </div>
    </div>

    {% if section.blocks.size > 0 %}
      <div class="brand-comparison-table__body">
        {% for block in section.blocks %}
          <div class="brand-comparison-table__grid brand-comparison-table__row" {{ block.shopify_attributes }}>
            <div class="brand-comparison-table__feature">
              {{ block.settings.feature }}
            </div>

            <div class="brand-comparison-table__value brand-comparison-table__value--{{ block.settings.brand_value }}">
              {% if block.settings.brand_value == 'check' %}
                <span class="brand-comparison-table__icon" aria-label="Yes">{{ section.settings.check_symbol }}</span>
              {% elsif block.settings.brand_value == 'x' %}
                <span class="brand-comparison-table__icon" aria-label="No">{{ section.settings.x_symbol }}</span>
              {% elsif block.settings.brand_text != blank %}
                <span class="brand-comparison-table__text-value">{{ block.settings.brand_text }}</span>
              {% endif %}
            </div>

            <div class="brand-comparison-table__value brand-comparison-table__value--{{ block.settings.others_value }}">
              {% if block.settings.others_value == 'check' %}
                <span class="brand-comparison-table__icon" aria-label="Yes">{{ section.settings.check_symbol }}</span>
              {% elsif block.settings.others_value == 'x' %}
                <span class="brand-comparison-table__icon" aria-label="No">{{ section.settings.x_symbol }}</span>
              {% elsif block.settings.others_text != blank %}
                <span class="brand-comparison-table__text-value">{{ block.settings.others_text }}</span>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% elsif request.design_mode %}
      <div class="brand-comparison-table__empty">
        Add comparison rows to build your table.
      </div>
    {% endif %}
  </div>
</section>

