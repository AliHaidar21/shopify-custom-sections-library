{{ 'premium-announcement-bar.css' | asset_url | stylesheet_tag }}

<section
  class="premium-announcement-bar premium-announcement-bar--{{ section.id }} premium-announcement-bar--{{ section.settings.position_mode }} {% if section.settings.pause_on_hover %}premium-announcement-bar--pause{% endif %}"
  data-premium-announcement-bar
  style="
    --pab-bg: {{ section.settings.background_color }};
    --pab-text: {{ section.settings.text_color }};
    --pab-accent: {{ section.settings.accent_color }};
    --pab-discount: {{ section.settings.discount_icon_color }};
    --pab-border: {{ section.settings.border_color }};
    --pab-height: {{ section.settings.bar_height }}px;
    --pab-font-size: {{ section.settings.font_size }}px;
    --pab-gap: {{ section.settings.item_gap }}px;
    --pab-speed: {{ section.settings.animation_speed }}s;
    --pab-z-index: {{ section.settings.z_index }};
  "
>
  <div class="premium-announcement-bar__viewport">
    <div class="premium-announcement-bar__track">
      {% for repeat in (1..2) %}
        <div class="premium-announcement-bar__group" aria-hidden="{% if repeat == 2 %}true{% else %}false{% endif %}">
          {% for block in section.blocks %}
            {% if block.type == 'announcement' %}
              {% if block.settings.link != blank %}
                <a
                  href="{{ block.settings.link }}"
                  class="premium-announcement-bar__item"
                  {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
                  {{ block.shopify_attributes }}
                >
              {% else %}
                <div class="premium-announcement-bar__item" {{ block.shopify_attributes }}>
              {% endif %}

                <span class="premium-announcement-bar__icon {% if block.settings.icon == 'discount' or block.settings.icon == 'check' %}premium-announcement-bar__icon--discount{% endif %}" aria-hidden="true">
                  {% case block.settings.icon %}
                    {% when 'truck' %}
                      <svg viewBox="0 0 24 24">
                        <path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
                      </svg>

                    {% when 'discount' %}
                      <svg viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                      </svg>

                    {% when 'check' %}
                      <svg viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                      </svg>

                    {% when 'shield' %}
                      <svg viewBox="0 0 24 24">
                        <path d="M12 3l7 4v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V7l7-4z"></path>
                        <path d="M9 12l2 2 4-4"></path>
                      </svg>

                    {% when 'sparkle' %}
                      <svg viewBox="0 0 24 24">
                        <path d="M12 2l2.2 6.2L20 10.5l-5.8 2.3L12 19l-2.2-6.2L4 10.5l5.8-2.3L12 2z"></path>
                      </svg>

                    {% when 'gift' %}
                      <svg viewBox="0 0 24 24">
                        <path d="M20 12v8H4v-8"></path>
                        <path d="M2 7h20v5H2z"></path>
                        <path d="M12 7v13"></path>
                        <path d="M12 7H8.5A2.5 2.5 0 1111 4.5L12 7z"></path>
                        <path d="M12 7h3.5A2.5 2.5 0 1013 4.5L12 7z"></path>
                      </svg>

                    {% else %}
                      <svg viewBox="0 0 24 24">
                        <path d="M12 2l2.2 6.2L20 10.5l-5.8 2.3L12 19l-2.2-6.2L4 10.5l5.8-2.3L12 2z"></path>
                      </svg>
                  {% endcase %}
                </span>

                <span class="premium-announcement-bar__text">
                  {{ block.settings.text }}
                </span>

              {% if block.settings.link != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script src="{{ 'premium-announcement-bar.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Premium announcement bar",
  "tag": "section",
  "class": "section-premium-announcement-bar",
  "settings": [
    {
      "type": "paragraph",
      "content": "Animated announcement bar extracted from the uploaded header style. Add announcement blocks below. The items automatically duplicate for a smooth infinite loop."
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation speed",
      "min": 12,
      "max": 80,
      "step": 4,
      "unit": "s",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "position_mode",
      "label": "Position mode",
      "default": "normal",
      "options": [
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "sticky",
          "label": "Sticky"
        },
        {
          "value": "fixed",
          "label": "Fixed to top"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "Use Normal above the header for the safest Shopify layout. Use Fixed only if your theme spacing is adjusted, because fixed bars sit above the page."
    },
    {
      "type": "range",
      "id": "bar_height",
      "label": "Bar height",
      "min": 30,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Text size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Space between items",
      "min": 20,
      "max": 90,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "z_index",
      "label": "Layer position",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 50
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#041F60"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Main icon color",
      "default": "#38B6CC"
    },
    {
      "type": "color",
      "id": "discount_icon_color",
      "label": "Discount/check icon color",
      "default": "#FFD700"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Bottom border",
      "default": "#38B6CC"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "truck",
          "options": [
            {
              "value": "truck",
              "label": "Delivery truck"
            },
            {
              "value": "discount",
              "label": "Discount check"
            },
            {
              "value": "check",
              "label": "Check circle"
            },
            {
              "value": "shield",
              "label": "Shield"
            },
            {
              "value": "sparkle",
              "label": "Sparkle"
            },
            {
              "value": "gift",
              "label": "Gift"
            }
          ]
        },
        {
          "type": "text",
          "id": "text",
          "label": "Announcement text",
          "default": "FREE DELIVERY on 2+ orders"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optional link"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium announcement bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "icon": "truck",
            "text": "FREE DELIVERY on 2+ orders"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "icon": "discount",
            "text": "$10 OFF on 3 orders"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "icon": "truck",
            "text": "FREE DELIVERY on 2+ orders"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "icon": "discount",
            "text": "$10 OFF on 3 orders"
          }
        }
      ]
    }
  ]
}
{% endschema %}
