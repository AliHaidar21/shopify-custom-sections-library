{{ 'video-proof-carousel.css' | asset_url | stylesheet_tag }}

<section
  class="video-proof-carousel video-proof-carousel--{{ section.id }}"
  style="
    --vpc-section-bg: {{ section.settings.section_background }};
    --vpc-text-color: {{ section.settings.text_color }};
    --vpc-card-radius: {{ section.settings.card_radius }}px;
    --vpc-gap: {{ section.settings.card_gap }}px;
    --vpc-max-width: {{ section.settings.max_width }}px;
    --vpc-mobile-card-width: {{ section.settings.mobile_card_width }}vw;
  "
>
  <div class="video-proof-carousel__inner">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="video-proof-carousel__header video-proof-carousel__header--{{ section.settings.text_alignment }}">
        {% if section.settings.eyebrow != blank %}
          <p class="video-proof-carousel__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="video-proof-carousel__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <div class="video-proof-carousel__subheading">
            {{ section.settings.subheading }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div
        class="video-proof-carousel__row"
        aria-label="{{ section.settings.accessibility_label | escape }}"
      >
        {% for block in section.blocks %}
          <div
            class="video-proof-carousel__card video-proof-carousel__card--{{ section.settings.video_ratio }}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.shopify_video != blank %}
              {{
                block.settings.shopify_video
                | video_tag:
                  autoplay: section.settings.autoplay,
                  loop: section.settings.loop_video,
                  muted: true,
                  controls: section.settings.show_controls,
                  playsinline: true,
                  preload: 'metadata',
                  class: 'video-proof-carousel__video'
              }}
            {% elsif block.settings.mp4_url != blank %}
              <video
                class="video-proof-carousel__video"
                {% if section.settings.autoplay %}autoplay{% endif %}
                {% if section.settings.loop_video %}loop{% endif %}
                {% if section.settings.show_controls %}controls{% endif %}
                muted
                playsinline
                preload="metadata"
                {% if block.settings.poster_image != blank %}
                  poster="{{ block.settings.poster_image | image_url: width: 900 }}"
                {% endif %}
                aria-label="{{ block.settings.video_label | escape }}"
              >
                <source src="{{ block.settings.mp4_url }}" type="video/mp4">
              </video>
            {% else %}
              <div class="video-proof-carousel__placeholder">
                <span>Add a video in this block</span>
              </div>
            {% endif %}

            {% if block.settings.caption != blank %}
              <p class="video-proof-carousel__caption">{{ block.settings.caption }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% elsif request.design_mode %}
      <div class="video-proof-carousel__empty">
        Add video blocks to build your carousel.
      </div>
    {% endif %}
  </div>
</section>

<script src="{{ 'video-proof-carousel.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Video proof carousel",
  "tag": "section",
  "class": "section-video-proof-carousel",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Real customer results"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See it in action"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Short autoplay videos that show the product experience.</p>"
    },
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Carousel accessibility label",
      "default": "Customer video previews"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 700,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "default": 1100
    },
    {
      "type": "select",
      "id": "video_ratio",
      "label": "Video shape",
      "default": "portrait",
      "options": [
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        }
      ]
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between videos",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Video corner radius",
      "min": 0,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_card_width",
      "label": "Mobile card width",
      "min": 35,
      "max": 90,
      "step": 5,
      "unit": "vw",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay videos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop_video",
      "label": "Loop videos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show video controls",
      "default": false
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#041f60"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "shopify_video",
          "label": "Shopify-hosted video"
        },
        {
          "type": "url",
          "id": "mp4_url",
          "label": "MP4 video URL"
        },
        {
          "type": "image_picker",
          "id": "poster_image",
          "label": "Poster image"
        },
        {
          "type": "text",
          "id": "video_label",
          "label": "Video accessibility label",
          "default": "Customer product video"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Video proof carousel",
      "blocks": [
        {
          "type": "video"
        },
        {
          "type": "video"
        },
        {
          "type": "video"
        }
      ]
    }
  ]
}
{% endschema %}
