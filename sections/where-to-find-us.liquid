{{ 'where-to-find-us.css' | asset_url | stylesheet_tag }}

{% if section.settings.load_playfair_font %}
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  >
{% endif %}

<section
  class="where-to-find-us where-to-find-us--{{ section.id }}"
  data-where-to-find-us
  data-pause-on-hover="{{ section.settings.pause_on_hover }}"
  style="
    --wtfu-bg: {{ section.settings.section_background }};
    --wtfu-title: {{ section.settings.title_color }};
    --wtfu-text: {{ section.settings.text_color }};
    --wtfu-muted: {{ section.settings.muted_text_color }};
    --wtfu-card-bg: {{ section.settings.card_background }};
    --wtfu-card-hover-bg: {{ section.settings.card_hover_background }};
    --wtfu-card-border: {{ section.settings.card_border_color }};
    --wtfu-card-hover-border: {{ section.settings.card_hover_border_color }};
    --wtfu-detail-bg: {{ section.settings.detail_background }};
    --wtfu-image-bg: {{ section.settings.image_background }};
    --wtfu-coming-bg: {{ section.settings.coming_soon_background }};
    --wtfu-coming-border: {{ section.settings.coming_soon_border_color }};
    --wtfu-radius: {{ section.settings.card_radius }}px;
    --wtfu-card-width: {{ section.settings.card_width }}px;
    --wtfu-mobile-card-width: {{ section.settings.mobile_card_width }}px;
    --wtfu-logo-size: {{ section.settings.logo_size }}px;
    --wtfu-mobile-logo-size: {{ section.settings.mobile_logo_size }}px;
    --wtfu-gap: {{ section.settings.card_gap }}px;
    --wtfu-mobile-gap: {{ section.settings.mobile_card_gap }}px;
    --wtfu-duration: {{ section.settings.animation_duration }}s;
    --wtfu-padding-top: {{ section.settings.padding_top }}px;
    --wtfu-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="where-to-find-us__header">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <div class="where-to-find-us__subtitle">
        {{ section.settings.subheading }}
      </div>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="where-to-find-us__loop-wrapper">
      <div class="where-to-find-us__viewport">
        <div class="where-to-find-us__track">
          {% for repeat in (1..2) %}
            {% for block in section.blocks %}
              <button
                class="where-to-find-us__card {% if block.settings.is_coming_soon %}where-to-find-us__card--coming-soon{% endif %}"
                type="button"
                data-location-card
                {{ block.shopify_attributes }}
              >
                {% if block.settings.is_coming_soon %}
                  <div class="where-to-find-us__coming-icon" aria-hidden="true">
                    {{ block.settings.coming_soon_icon }}
                  </div>
                {% else %}
                  <div class="where-to-find-us__image-wrapper">
                    {% if block.settings.image != blank %}
                      {{
                        block.settings.image
                        | image_url: width: 400
                        | image_tag:
                          loading: 'lazy',
                          class: 'where-to-find-us__logo',
                          alt: block.settings.image_alt
                      }}
                    {% else %}
                      <span class="where-to-find-us__image-placeholder" aria-hidden="true">
                        {{ block.settings.placeholder_icon }}
                      </span>
                    {% endif %}
                  </div>
                {% endif %}

                {% if block.settings.name != blank %}
                  <span class="where-to-find-us__name">
                    {{ block.settings.name }}
                  </span>
                {% endif %}

                {% if block.settings.location_line != blank or block.settings.address_line != blank %}
                  <span class="where-to-find-us__detail">
                    {% if block.settings.location_line != blank %}
                      <span>{{ block.settings.location_line }}</span>
                    {% endif %}

                    {% if block.settings.address_line != blank %}
                      <small>{{ block.settings.address_line }}</small>
                    {% endif %}
                  </span>
                {% endif %}
              </button>
            {% endfor %}
          {% endfor %}
        </div>
      </div>
    </div>
  {% elsif request.design_mode %}
    <div class="where-to-find-us__empty">
      Add location blocks to build your animated location row.
    </div>
  {% endif %}

  {% if section.settings.footer_text != blank %}
    <div class="where-to-find-us__footer">
      <span>{{ section.settings.footer_text }}</span>
    </div>
  {% endif %}
</section>

<script src="{{ 'where-to-find-us.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Where to find us",
  "tag": "section",
  "class": "section-where-to-find-us",
  "settings": [
    {
      "type": "checkbox",
      "id": "load_playfair_font",
      "label": "Load Playfair Display font",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Where to find us"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Find our products at selected partner locations.</p>"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer text",
      "default": "More locations coming soon."
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause animation on hover",
      "default": true
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "Animation speed",
      "min": 18,
      "max": 90,
      "step": 2,
      "unit": "s",
      "default": 46
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Desktop card width",
      "min": 180,
      "max": 340,
      "step": 10,
      "unit": "px",
      "default": 260
    },
    {
      "type": "range",
      "id": "mobile_card_width",
      "label": "Mobile card width",
      "min": 150,
      "max": 260,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Desktop card gap",
      "min": 12,
      "max": 44,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "mobile_card_gap",
      "label": "Mobile card gap",
      "min": 10,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "logo_size",
      "label": "Desktop logo circle size",
      "min": 60,
      "max": 140,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "mobile_logo_size",
      "label": "Mobile logo circle size",
      "min": 48,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card radius",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#2C3E4E"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#2C3E4E"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#5C6F7E"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_hover_background",
      "label": "Card hover background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#DED8D2"
    },
    {
      "type": "color",
      "id": "card_hover_border_color",
      "label": "Card hover border color",
      "default": "#A39385"
    },
    {
      "type": "color",
      "id": "detail_background",
      "label": "Detail background",
      "default": "#F9F7F2"
    },
    {
      "type": "color",
      "id": "image_background",
      "label": "Logo circle background",
      "default": "#F9F7F2"
    },
    {
      "type": "color",
      "id": "coming_soon_background",
      "label": "Coming soon background",
      "default": "#FFFEE8"
    },
    {
      "type": "color",
      "id": "coming_soon_border_color",
      "label": "Coming soon border",
      "default": "#A39385"
    }
  ],
  "blocks": [
    {
      "type": "location",
      "name": "Location",
      "settings": [
        {
          "type": "checkbox",
          "id": "is_coming_soon",
          "label": "Use as coming soon card",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Location image or logo"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "Location logo"
        },
        {
          "type": "text",
          "id": "placeholder_icon",
          "label": "Placeholder icon",
          "default": "📍"
        },
        {
          "type": "text",
          "id": "coming_soon_icon",
          "label": "Coming soon icon",
          "default": "✨"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Location name",
          "default": "Location one"
        },
        {
          "type": "text",
          "id": "location_line",
          "label": "Location line",
          "default": "📍 City, Country"
        },
        {
          "type": "text",
          "id": "address_line",
          "label": "Address line",
          "default": "Add the full address or store details here"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Where to find us",
      "blocks": [
        {
          "type": "location",
          "settings": {
            "name": "Location one",
            "location_line": "📍 City, Country",
            "address_line": "Add the full address or store details here"
          }
        },
        {
          "type": "location",
          "settings": {
            "name": "Location two",
            "location_line": "📍 City, Country",
            "address_line": "Add the full address or store details here"
          }
        },
        {
          "type": "location",
          "settings": {
            "name": "Location three",
            "location_line": "📍 City, Country",
            "address_line": "Add the full address or store details here"
          }
        },
        {
          "type": "location",
          "settings": {
            "is_coming_soon": true,
            "name": "Coming soon",
            "location_line": "📍 More locations coming",
            "address_line": "Stay tuned for updates"
          }
        }
      ]
    }
  ]
}
{% endschema %}
