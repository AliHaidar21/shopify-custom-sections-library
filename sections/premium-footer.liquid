{{ 'premium-footer.css' | asset_url | stylesheet_tag }}

<footer
  class="premium-footer premium-footer--{{ section.id }}"
  data-premium-footer
  style="
    --pf-bg: {{ section.settings.background_color }};
    --pf-panel: {{ section.settings.panel_color }};
    --pf-text: {{ section.settings.text_color }};
    --pf-muted: {{ section.settings.muted_color }};
    --pf-accent: {{ section.settings.accent_color }};
    --pf-border: {{ section.settings.border_color }};
    --pf-button-bg: {{ section.settings.button_background }};
    --pf-button-text: {{ section.settings.button_text_color }};
    --pf-max-width: {{ section.settings.max_width }}px;
    --pf-radius: {{ section.settings.border_radius }}px;
    --pf-section-padding-top: {{ section.settings.padding_top }}px;
    --pf-section-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="premium-footer__shell">
    <div class="premium-footer__main">
      <div class="premium-footer__brand-column">
        <a href="{{ routes.root_url }}" class="premium-footer__brand" aria-label="{{ section.settings.brand_text | escape }}">
          {% if section.settings.logo != blank %}
            {{
              section.settings.logo
              | image_url: width: 520
              | image_tag:
                loading: 'lazy',
                class: 'premium-footer__logo',
                alt: section.settings.brand_text
            }}
          {% else %}
            <span class="premium-footer__text-logo">{{ section.settings.brand_text }}</span>
          {% endif %}
        </a>

        {% if section.settings.show_brand_divider %}
          <div class="premium-footer__brand-divider" aria-hidden="true">
            <span></span>
            <i>✦</i>
            <span></span>
          </div>
        {% endif %}

        {% if section.settings.about_text != blank %}
          <div class="premium-footer__about">
            {{ section.settings.about_text }}
          </div>
        {% endif %}

        {% if section.settings.trust_text != blank %}
          <div class="premium-footer__brand-trust">
            <span class="premium-footer__brand-trust-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M12 3l7 4v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V7l7-4z"></path>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
            </span>
            <span>{{ section.settings.trust_text }}</span>
          </div>
        {% endif %}
      </div>

      <div class="premium-footer__links-column">
        {% if section.settings.quick_links_heading != blank %}
          <h2 class="premium-footer__heading">{{ section.settings.quick_links_heading }}</h2>
        {% endif %}

        <div class="premium-footer__quick-links">
          {% for block in section.blocks %}
            {% if block.type == 'quick_link' %}
              <a
                class="premium-footer__quick-link"
                href="{{ block.settings.link | default: '#' }}"
                {{ block.shopify_attributes }}
              >
                <span class="premium-footer__animated-border" aria-hidden="true">
                  <span></span><span></span><span></span><span></span>
                </span>

                <span class="premium-footer__quick-icon" aria-hidden="true">
                  {{ block.settings.icon }}
                </span>

                <span class="premium-footer__quick-label">
                  {{ block.settings.label }}
                </span>

                <span class="premium-footer__quick-arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M9 5l7 7-7 7"></path>
                  </svg>
                </span>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="premium-footer__care-column">
        {% if section.settings.care_heading != blank %}
          <h2 class="premium-footer__heading">{{ section.settings.care_heading }}</h2>
        {% endif %}

        <div class="premium-footer__care-links">
          {% if section.settings.care_menu != blank %}
            {% for link in section.settings.care_menu.links %}
              <a class="premium-footer__care-link" href="{{ link.url }}">
                <span class="premium-footer__care-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="9"></circle>
                    <path d="M9.5 9a2.8 2.8 0 015 1.7c0 2.2-2.5 2.4-2.5 4.3"></path>
                    <path d="M12 18h.01"></path>
                  </svg>
                </span>
                <span>{{ link.title }}</span>
                <span class="premium-footer__care-arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M9 5l7 7-7 7"></path>
                  </svg>
                </span>
              </a>
            {% endfor %}
          {% endif %}

          {% for block in section.blocks %}
            {% if block.type == 'care_link' %}
              <a
                class="premium-footer__care-link"
                href="{{ block.settings.link | default: '#' }}"
                {{ block.shopify_attributes }}
              >
                <span class="premium-footer__care-icon" aria-hidden="true">
                  {{ block.settings.icon }}
                </span>
                <span>{{ block.settings.label }}</span>
                <span class="premium-footer__care-arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M9 5l7 7-7 7"></path>
                  </svg>
                </span>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="premium-footer__connect-card">
        {% if section.settings.newsletter_heading != blank %}
          <h2 class="premium-footer__connect-heading">{{ section.settings.newsletter_heading }}</h2>
        {% endif %}

        <div class="premium-footer__connect-divider" aria-hidden="true">
          <span></span>
          <i>✦</i>
          <span></span>
        </div>

        {% if section.settings.newsletter_text != blank %}
          <p class="premium-footer__connect-text">{{ section.settings.newsletter_text }}</p>
        {% endif %}

        <div class="premium-footer__socials">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24">
                <rect x="4" y="4" width="16" height="16" rx="5"></rect>
                <circle cx="12" cy="12" r="3.5"></circle>
                <path d="M17.5 6.5h.01"></path>
              </svg>
            </a>
          {% endif %}

          {% if section.settings.facebook_url != blank %}
            <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24">
                <path d="M14 8h2V4h-3c-3 0-5 2-5 5v3H5v4h3v4h4v-4h3l1-4h-4V9c0-.6.4-1 1-1h1z"></path>
              </svg>
            </a>
          {% endif %}

          {% if section.settings.tiktok_url != blank %}
            <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">
              <svg viewBox="0 0 24 24">
                <path d="M15 4c.5 3.3 2.4 5 5 5v4c-2 0-3.8-.6-5-1.6V16a5 5 0 11-5-5c.4 0 .7 0 1 .1V15a2 2 0 102 1.7V4h2z"></path>
              </svg>
            </a>
          {% endif %}

          {% if section.settings.pinterest_url != blank %}
            <a href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener" aria-label="Pinterest">
              <svg viewBox="0 0 24 24">
                <path d="M12 3a8.5 8.5 0 00-3 16.4c-.1-.8-.1-1.8 0-2.6l1.1-4.5s-.3-.6-.3-1.5c0-1.4.8-2.5 1.8-2.5.9 0 1.3.7 1.3 1.5 0 .9-.6 2.3-.9 3.6-.2 1.1.6 2 1.7 2 2 0 3.4-2.5 3.4-5.4 0-2.2-1.5-3.9-4.2-3.9-3 0-4.8 2.2-4.8 4.6 0 .8.2 1.4.7 1.9.2.2.2.3.1.6l-.3 1.1c-.1.3-.3.4-.6.3-1.6-.7-2.3-2.4-2.3-4.2C5.7 7 8.4 3 12 3z"></path>
              </svg>
            </a>
          {% endif %}

          {% if section.settings.youtube_url != blank %}
            <a href="{{ section.settings.youtube_url }}" target="_blank" rel="noopener" aria-label="YouTube">
              <svg viewBox="0 0 24 24">
                <path d="M21 8s-.2-1.5-.8-2.1c-.8-.8-1.6-.8-2-.9C15.4 4.8 12 4.8 12 4.8s-3.4 0-6.2.2c-.4.1-1.2.1-2 .9C3.2 6.5 3 8 3 8s-.2 1.8-.2 3.6v1.7C2.8 15.2 3 17 3 17s.2 1.5.8 2.1c.8.8 1.8.8 2.3.9 1.7.2 5.9.2 5.9.2s3.4 0 6.2-.2c.4-.1 1.2-.1 2-.9.6-.6.8-2.1.8-2.1s.2-1.8.2-3.6v-1.7C21.2 9.8 21 8 21 8z"></path>
                <path d="M10 9l5 3-5 3V9z"></path>
              </svg>
            </a>
          {% endif %}
        </div>

        {% if section.settings.show_newsletter %}
          <div class="premium-footer__newsletter">
            {% if section.settings.newsletter_form_heading != blank %}
              <h3>{{ section.settings.newsletter_form_heading }}</h3>
            {% endif %}

            {% form 'customer', class: 'premium-footer__newsletter-form' %}
              <input type="hidden" name="contact[tags]" value="newsletter">

              <div class="premium-footer__newsletter-row">
                <input
                  type="email"
                  name="contact[email]"
                  value="{{ form.email }}"
                  placeholder="{{ section.settings.newsletter_placeholder }}"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  required
                >
                <button type="submit">{{ section.settings.newsletter_button_text }}</button>
              </div>

              {% if form.posted_successfully? %}
                <p class="premium-footer__form-message premium-footer__form-message--success">
                  {{ section.settings.newsletter_success_text }}
                </p>
              {% elsif form.errors %}
                <p class="premium-footer__form-message premium-footer__form-message--error">
                  {{ form.errors | default_errors }}
                </p>
              {% endif %}
            {% endform %}

            {% if section.settings.newsletter_privacy_text != blank %}
              <p class="premium-footer__privacy-line">
                <span aria-hidden="true">⌕</span>
                {{ section.settings.newsletter_privacy_text }}
              </p>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="premium-footer__trust-bar">
      {% for block in section.blocks %}
        {% if block.type == 'trust_badge' %}
          <div class="premium-footer__trust-item" {{ block.shopify_attributes }}>
            <span class="premium-footer__trust-icon" aria-hidden="true">{{ block.settings.icon }}</span>
            <span>
              <strong>{{ block.settings.heading }}</strong>
              <small>{{ block.settings.text }}</small>
            </span>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="premium-footer__bottom">
<div class="premium-footer__copyright">
        {{ section.settings.copyright_text | replace: '[year]', 'now' | date: '%Y' | replace: '[brand]', section.settings.brand_text }}
      </div>

      <div class="premium-footer__legal-links">
        {% if section.settings.legal_menu != blank %}
          {% for link in section.settings.legal_menu.links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        {% endif %}

        {% for block in section.blocks %}
          {% if block.type == 'legal_link' %}
            <a href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </a>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.settings.show_back_to_top %}
        <button class="premium-footer__back-to-top" type="button" aria-label="Back to top" data-premium-footer-top>
          <svg viewBox="0 0 24 24">
            <path d="M6 15l6-6 6 6"></path>
          </svg>
        </button>
      {% endif %}
    </div>
  </div>
</footer>

<script src="{{ 'premium-footer.js' | asset_url }}" defer></script>

