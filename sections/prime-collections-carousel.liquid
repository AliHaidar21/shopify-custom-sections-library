{{ 'prime-collections-carousel.css' | asset_url | stylesheet_tag }}

<section
  class="prime-collections-carousel prime-collections-carousel--{{ section.id }}"
  data-prime-collections-carousel
  style="
    --pcc-section-bg: {{ section.settings.section_background }};
    --pcc-title-color: {{ section.settings.title_color }};
    --pcc-arrow-color: {{ section.settings.arrow_color }};
    --pcc-progress-color: {{ section.settings.progress_color }};
    --pcc-progress-track: {{ section.settings.progress_track_color }};
    --pcc-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --pcc-card-radius: {{ section.settings.card_radius }}px;
    --pcc-card-height-desktop: {{ section.settings.card_height_desktop }}px;
    --pcc-card-height-mobile: {{ section.settings.card_height_mobile }}px;
    --pcc-card-width-desktop: {{ section.settings.card_width_desktop }}px;
    --pcc-card-width-mobile: {{ section.settings.card_width_mobile }}vw;
    --pcc-padding-top: {{ section.settings.padding_top }}px;
    --pcc-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="prime-collections-carousel__inner">
    {% if section.settings.section_title != blank %}
      <div class="prime-collections-carousel__header">
        <h2 class="prime-collections-carousel__title">
          {{ section.settings.section_title }}
        </h2>
      </div>
    {% endif %}

    <div class="prime-collections-carousel__viewport">
      <div class="prime-collections-carousel__track" data-pcc-track>
        {% for block in section.blocks %}
          {% if block.type == 'collection_card' %}
            {% liquid
              assign card_image = ''
              if block.settings.image != blank
                assign card_image = block.settings.image | image_url: width: 1200
              elsif block.settings.image_url != blank
                assign card_image = block.settings.image_url
              endif

              assign card_title = block.settings.collection_name
              assign card_link = block.settings.link
              assign is_clickable = false

              if card_link != blank
                assign is_clickable = true
              endif
            %}

            {% if is_clickable %}
              <a
                class="prime-collections-carousel__card"
                href="{{ card_link }}"
                {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
                {{ block.shopify_attributes }}
              >
            {% else %}
              <div
                class="prime-collections-carousel__card"
                role="group"
                aria-label="{{ card_title | escape }}"
                {{ block.shopify_attributes }}
              >
            {% endif %}

              {% if card_image != blank %}
                <span
                  class="prime-collections-carousel__card-bg"
                  style="background-image: url('{{ card_image }}');"
                  aria-hidden="true"
                ></span>
              {% else %}
                <span class="prime-collections-carousel__card-bg prime-collections-carousel__card-bg--empty" aria-hidden="true"></span>
              {% endif %}

              <span class="prime-collections-carousel__overlay" aria-hidden="true"></span>

              {% if section.settings.show_coming_soon_badge and block.settings.show_coming_soon %}
                <span class="prime-collections-carousel__badge">
                  {% if block.settings.badge_text != blank %}
                    {{ block.settings.badge_text }}
                  {% else %}
                    {{ section.settings.badge_text }}
                  {% endif %}
                </span>
              {% endif %}

              <span class="prime-collections-carousel__card-title">
                {{ card_title }}
              </span>

            {% if is_clickable %}
              </a>
            {% else %}
              </div>
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="prime-collections-carousel__bottom">
      {% if section.settings.show_progress %}
        <div class="prime-collections-carousel__progress" aria-hidden="true">
          <span class="prime-collections-carousel__progress-fill" data-pcc-progress></span>
        </div>
      {% endif %}

      {% if section.settings.show_arrows %}
        <div class="prime-collections-carousel__arrows">
          <button class="prime-collections-carousel__arrow" type="button" aria-label="Previous collections" data-pcc-prev>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M15 5l-7 7 7 7"></path>
            </svg>
          </button>

          <button class="prime-collections-carousel__arrow" type="button" aria-label="Next collections" data-pcc-next>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script src="{{ 'prime-collections-carousel.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Prime carousel",
  "tag": "section",
  "class": "section-prime-collections-carousel",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Discover our collections"
    },
    {
      "type": "checkbox",
      "id": "show_coming_soon_badge",
      "label": "Show Coming Soon badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Default badge text",
      "default": "Coming Soon"
    },
    {
      "type": "header",
      "content": "Carousel controls"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_progress",
      "label": "Show progress line",
      "default": true
    },
    {
      "type": "range",
      "id": "card_width_desktop",
      "label": "Desktop card width",
      "min": 280,
      "max": 520,
      "step": 10,
      "unit": "px",
      "default": 360
    },
    {
      "type": "range",
      "id": "card_width_mobile",
      "label": "Mobile card width",
      "min": 70,
      "max": 90,
      "step": 1,
      "unit": "vw",
      "default": 82
    },
    {
      "type": "range",
      "id": "card_height_desktop",
      "label": "Desktop card height",
      "min": 180,
      "max": 420,
      "step": 10,
      "unit": "px",
      "default": 260
    },
    {
      "type": "range",
      "id": "card_height_mobile",
      "label": "Mobile card height",
      "min": 170,
      "max": 320,
      "step": 10,
      "unit": "px",
      "default": 220
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image dark overlay",
      "min": 10,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#071E22"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "#071E22"
    },
    {
      "type": "color",
      "id": "progress_color",
      "label": "Progress active color",
      "default": "#071E22"
    },
    {
      "type": "color",
      "id": "progress_track_color",
      "label": "Progress track color",
      "default": "#E6ECEE"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        {
          "type": "text",
          "id": "collection_name",
          "label": "Collection name",
          "default": "Collection name"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image picker"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL fallback"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optional link"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_coming_soon",
          "label": "Show Coming Soon badge on this card",
          "default": true
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text override",
          "default": "Coming Soon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Prime carousel",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "collection_name": "Kitchen",
            "image_url": "https://cdn.shopify.com/s/files/1/0823/7092/0706/files/IMG_9473.jpg?v=1781104685",
            "show_coming_soon": true,
            "badge_text": "Coming Soon"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "collection_name": "Home Essentials",
            "image_url": "https://cdn.shopify.com/s/files/1/0823/7092/0706/files/7B750BF9-1B92-4B6D-8EAE-D6594F46177C.jpg?v=1781104858",
            "show_coming_soon": true,
            "badge_text": "Coming Soon"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "collection_name": "On Sale",
            "image_url": "https://cdn.shopify.com/s/files/1/0823/7092/0706/files/IMG_9476.jpg?v=1781105092",
            "show_coming_soon": true,
            "badge_text": "Coming Soon"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "collection_name": "Fitness & Sports",
            "image_url": "https://cdn.shopify.com/s/files/1/0823/7092/0706/files/D49CAD23-21BF-4722-A37B-C263F11D2FCB.jpg?v=1781104610",
            "show_coming_soon": true,
            "badge_text": "Coming Soon"
          }
        }
      ]
    }
  ]
}
{% endschema %}
