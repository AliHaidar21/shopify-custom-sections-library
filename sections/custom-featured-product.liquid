{{ 'custom-featured-product.css' | asset_url | stylesheet_tag }}

{% liquid
  assign selected_product = section.settings.product

  if selected_product == blank and product != blank
    assign selected_product = product
  endif

  assign current_variant = selected_product.selected_or_first_available_variant
  assign product_form_id = 'CustomFeaturedProductForm-' | append: section.id

  assign has_quantity_block = false
  for block in section.blocks
    if block.type == 'quantity_selector'
      assign has_quantity_block = true
    endif
  endfor
%}

<section
  class="custom-featured-product custom-featured-product--{{ section.id }}"
  data-cfp-section
  data-root-url="{{ routes.root_url }}"
  data-ajax-cart="{{ section.settings.enable_ajax_cart }}"
  data-after-add="{{ section.settings.after_add_behavior }}"
  data-money-format="{{ shop.money_format | escape }}"
  style="
    --cfp-bg: {{ section.settings.section_background }};
    --cfp-card-bg: {{ section.settings.card_background }};
    --cfp-text: {{ section.settings.text_color }};
    --cfp-muted: {{ section.settings.muted_text_color }};
    --cfp-accent: {{ section.settings.accent_color }};
    --cfp-border: {{ section.settings.border_color }};
    --cfp-button-bg: {{ section.settings.button_background }};
    --cfp-button-text: {{ section.settings.button_text_color }};
    --cfp-radius: {{ section.settings.card_radius }}px;
    --cfp-media-radius: {{ section.settings.media_radius }}px;
    --cfp-max-width: {{ section.settings.max_width }}px;
    --cfp-padding-top: {{ section.settings.padding_top }}px;
    --cfp-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  {% if selected_product != blank %}
    <div class="custom-featured-product__inner">
      <div class="custom-featured-product__media-column">
        <div class="custom-featured-product__media-card">
          {% assign first_image = selected_product.featured_media.preview_image %}

          {% if first_image != blank %}
            {{
              first_image
              | image_url: width: 1200
              | image_tag:
                loading: 'eager',
                class: 'custom-featured-product__main-image',
                alt: selected_product.title,
                data-main-product-image: ''
            }}
          {% else %}
            <div class="custom-featured-product__main-placeholder" data-main-product-image>
              Add product images
            </div>
          {% endif %}
        </div>

        {% if selected_product.media.size > 1 %}
          <div class="custom-featured-product__thumbs" aria-label="Product media thumbnails">
            {% for media in selected_product.media %}
              {% if media.media_type == 'image' and media.preview_image != blank %}
                <button
                  type="button"
                  class="custom-featured-product__thumb {% if forloop.first %}is-active{% endif %}"
                  data-cfp-thumb
                  data-image-src="{{ media.preview_image | image_url: width: 1200 }}"
                  aria-label="Show product image {{ forloop.index }}"
                >
                  {{
                    media.preview_image
                    | image_url: width: 220
                    | image_tag:
                      loading: 'lazy',
                      class: 'custom-featured-product__thumb-image',
                      alt: selected_product.title
                  }}
                </button>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="custom-featured-product__info-column">
        {% form 'product', selected_product, id: product_form_id, class: 'custom-featured-product__form', data-product-form: '' %}
          <input
            type="hidden"
            name="id"
            value="{{ current_variant.id }}"
            data-cfp-variant-input
          >

          {% unless has_quantity_block %}
            <input type="hidden" name="quantity" value="1" data-cfp-quantity-input>
          {% endunless %}

          <script type="application/json" data-cfp-variants>
            {{ selected_product.variants | json }}
          </script>

          {% for block in section.blocks %}
            {% case block.type %}

              {% when 'title' %}
                <div class="custom-featured-product__block custom-featured-product__title-block" {{ block.shopify_attributes }}>
                  {% if block.settings.kicker != blank %}
                    <p class="custom-featured-product__kicker">{{ block.settings.kicker }}</p>
                  {% endif %}

                  <h2 class="custom-featured-product__title">
                    {% if block.settings.custom_title != blank %}
                      {{ block.settings.custom_title }}
                    {% else %}
                      {{ selected_product.title }}
                    {% endif %}
                  </h2>
                </div>

              {% when 'rating' %}
                <div class="custom-featured-product__block custom-featured-product__rating" {{ block.shopify_attributes }}>
                  <div class="custom-featured-product__stars" aria-label="{{ block.settings.star_count }} out of 5 stars">
                    {% for i in (1..5) %}
                      <span class="{% if i > block.settings.star_count %}is-empty{% endif %}">★</span>
                    {% endfor %}
                  </div>

                  {% if block.settings.rating_text != blank %}
                    <span class="custom-featured-product__rating-text">{{ block.settings.rating_text }}</span>
                  {% endif %}
                </div>

              {% when 'reviews' %}
                <div class="custom-featured-product__block custom-featured-product__reviews" {{ block.shopify_attributes }}>
                  {% if block.settings.reviews_link != blank %}
                    <a href="{{ block.settings.reviews_link }}">{{ block.settings.reviews_text }}</a>
                  {% else %}
                    <span>{{ block.settings.reviews_text }}</span>
                  {% endif %}
                </div>

              {% when 'price' %}
                <div class="custom-featured-product__block custom-featured-product__price-wrap" data-cfp-price {{ block.shopify_attributes }}>
                  <span class="custom-featured-product__price" data-cfp-current-price>
                    {{ current_variant.price | money }}
                  </span>

                  {% if block.settings.show_compare_price %}
                    <span
                      class="custom-featured-product__compare {% if current_variant.compare_at_price <= current_variant.price or current_variant.compare_at_price == blank %}is-hidden{% endif %}"
                      data-cfp-compare-price
                    >
                      {% if current_variant.compare_at_price > current_variant.price %}
                        {{ current_variant.compare_at_price | money }}
                      {% endif %}
                    </span>
                  {% endif %}

                  {% if block.settings.sale_badge != blank %}
                    <span
                      class="custom-featured-product__sale-badge {% if current_variant.compare_at_price <= current_variant.price or current_variant.compare_at_price == blank %}is-hidden{% endif %}"
                      data-cfp-sale-badge
                    >
                      {{ block.settings.sale_badge }}
                    </span>
                  {% endif %}
                </div>

              {% when 'variant_picker' %}
                {% unless selected_product.has_only_default_variant %}
                  <div class="custom-featured-product__block custom-featured-product__variants" {{ block.shopify_attributes }}>
                    {% for option in selected_product.options_with_values %}
                      {% assign option_index = option.position | minus: 1 %}

                      <fieldset class="custom-featured-product__option">
                        <legend>{{ option.name }}</legend>

                        <div class="custom-featured-product__option-values">
                          {% for value in option.values %}
                            {% assign is_checked = false %}
                            {% if current_variant.options[option_index] == value %}
                              {% assign is_checked = true %}
                            {% endif %}

                            <label class="custom-featured-product__option-pill">
                              <input
                                type="radio"
                                name="cfp-option-{{ option.position }}-{{ section.id }}"
                                value="{{ value | escape }}"
                                data-cfp-option
                                data-option-position="{{ option.position }}"
                                {% if is_checked %}checked{% endif %}
                              >
                              <span>{{ value }}</span>
                            </label>
                          {% endfor %}
                        </div>
                      </fieldset>
                    {% endfor %}
                  </div>
                {% endunless %}

              {% when 'bullet' %}
                {% if block.settings.text != blank %}
                  <div class="custom-featured-product__block custom-featured-product__bullet" {{ block.shopify_attributes }}>
                    <span class="custom-featured-product__bullet-icon">{{ block.settings.icon }}</span>
                    <span>{{ block.settings.text }}</span>
                  </div>
                {% endif %}

              {% when 'quantity_selector' %}
                <div class="custom-featured-product__block custom-featured-product__quantity-row" {{ block.shopify_attributes }}>
                  {% if block.settings.label != blank %}
                    <label for="Quantity-{{ section.id }}">{{ block.settings.label }}</label>
                  {% endif %}

                  <div class="custom-featured-product__quantity">
                    <button type="button" data-cfp-quantity-minus aria-label="Decrease quantity">−</button>
                    <input
                      id="Quantity-{{ section.id }}"
                      type="number"
                      name="quantity"
                      value="{{ block.settings.default_quantity }}"
                      min="1"
                      data-cfp-quantity-input
                    >
                    <button type="button" data-cfp-quantity-plus aria-label="Increase quantity">+</button>
                  </div>
                </div>

              {% when 'add_to_cart' %}
                <div class="custom-featured-product__block custom-featured-product__actions" {{ block.shopify_attributes }}>
                  <button
                    type="submit"
                    class="custom-featured-product__add"
                    data-cfp-add-button
                    {% unless current_variant.available %}disabled{% endunless %}
                  >
                    <span data-cfp-add-text>
                      {% if current_variant.available %}
                        {{ block.settings.button_text }}
                      {% else %}
                        {{ block.settings.sold_out_text }}
                      {% endif %}
                    </span>
                  </button>

                  <p class="custom-featured-product__form-message" data-cfp-message aria-live="polite"></p>
                </div>

              {% when 'trust_item' %}
                <div class="custom-featured-product__block custom-featured-product__trust-item" {{ block.shopify_attributes }}>
                  <span class="custom-featured-product__trust-icon">
                    {% case block.settings.icon %}
                      {% when 'truck' %}
                        <svg viewBox="0 0 24 24"><path d="M3 7h11v10H3z"></path><path d="M14 10h4l3 3v4h-7z"></path><path d="M7 20a2 2 0 100-4 2 2 0 000 4z"></path><path d="M18 20a2 2 0 100-4 2 2 0 000 4z"></path></svg>
                      {% when 'shield' %}
                        <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                      {% when 'leaf' %}
                        <svg viewBox="0 0 24 24"><path d="M5 19c8 0 14-6 14-14-8 0-14 6-14 14z"></path><path d="M5 19l9-9"></path></svg>
                      {% when 'heart' %}
                        <svg viewBox="0 0 24 24"><path d="M20.8 4.6a5.5 5.5 0 00-7.8 0L12 5.6l-1-1a5.5 5.5 0 00-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 000-7.8z"></path></svg>
                      {% when 'sparkle' %}
                        <svg viewBox="0 0 24 24"><path d="M12 3l1.7 5.3L19 10l-5.3 1.7L12 17l-1.7-5.3L5 10l5.3-1.7L12 3z"></path></svg>
                      {% when 'clock' %}
                        <svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path><path d="M12 7v5l3 2"></path></svg>
                      {% else %}
                        <svg viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"></path></svg>
                    {% endcase %}
                  </span>

                  <span class="custom-featured-product__trust-copy">
                    {% if block.settings.title != blank %}
                      <strong>{{ block.settings.title }}</strong>
                    {% endif %}

                    {% if block.settings.text != blank %}
                      <small>{{ block.settings.text }}</small>
                    {% endif %}
                  </span>
                </div>

              {% when 'collapsible' %}
                <div class="custom-featured-product__block custom-featured-product__collapsible" {{ block.shopify_attributes }}>
                  <button type="button" class="custom-featured-product__collapsible-button" data-cfp-collapsible-button>
                    <span>{{ block.settings.title }}</span>
                    <span aria-hidden="true">+</span>
                  </button>

                  <div class="custom-featured-product__collapsible-content" data-cfp-collapsible-content hidden>
                    {{ block.settings.content }}
                  </div>
                </div>

              {% when 'video_carousel' %}
                <div class="custom-featured-product__block custom-featured-product__video-carousel" data-cfp-video-carousel {{ block.shopify_attributes }}>
                  {% if block.settings.title != blank %}
                    <h3>{{ block.settings.title }}</h3>
                  {% endif %}

                  <div class="custom-featured-product__video-frame">
                    {% assign video_count = 0 %}

                    {% if block.settings.video_1 != blank %}
                      {% assign video_count = video_count | plus: 1 %}
                      <div class="custom-featured-product__video-slide is-active" data-cfp-video-slide>
                        {{ block.settings.video_1 | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
                      </div>
                    {% endif %}

                    {% if block.settings.video_2 != blank %}
                      {% assign video_count = video_count | plus: 1 %}
                      <div class="custom-featured-product__video-slide" data-cfp-video-slide>
                        {{ block.settings.video_2 | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
                      </div>
                    {% endif %}

                    {% if block.settings.video_3 != blank %}
                      {% assign video_count = video_count | plus: 1 %}
                      <div class="custom-featured-product__video-slide" data-cfp-video-slide>
                        {{ block.settings.video_3 | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
                      </div>
                    {% endif %}

                    {% if video_count == 0 %}
                      <div class="custom-featured-product__video-placeholder">
                        Add videos to this block
                      </div>
                    {% endif %}

                    {% if video_count > 1 %}
                      <button type="button" class="custom-featured-product__video-arrow custom-featured-product__video-arrow--prev" data-cfp-video-prev aria-label="Previous video">‹</button>
                      <button type="button" class="custom-featured-product__video-arrow custom-featured-product__video-arrow--next" data-cfp-video-next aria-label="Next video">›</button>
                    {% endif %}
                  </div>
                </div>

            {% endcase %}
          {% endfor %}

          {{ form | payment_terms }}
        {% endform %}
      </div>
    </div>
  {% else %}
    <div class="custom-featured-product__empty">
      Choose a product in the section settings.
    </div>
  {% endif %}
</section>

<script src="{{ 'custom-featured-product.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Featured product builder",
  "tag": "section",
  "class": "section-featured-product-builder",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Leave blank on a product template to use the current product."
    },
    {
      "type": "checkbox",
      "id": "enable_ajax_cart",
      "label": "Use Ajax add to cart",
      "default": true
    },
    {
      "type": "select",
      "id": "after_add_behavior",
      "label": "After add to cart",
      "default": "stay",
      "options": [
        {
          "value": "stay",
          "label": "Stay on page"
        },
        {
          "value": "cart",
          "label": "Go to cart page"
        },
        {
          "value": "checkout",
          "label": "Go to checkout"
        }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 900,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card radius",
      "min": 8,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "media_radius",
      "label": "Media radius",
      "min": 8,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#38B6CC"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#E1E6EF"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Add to cart button background",
      "default": "#041F60"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Add to cart button text",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "Small top text",
          "default": "Premium product"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom title",
          "info": "Leave blank to use the Shopify product title."
        }
      ]
    },
    {
      "type": "rating",
      "name": "Stars",
      "settings": [
        {
          "type": "range",
          "id": "star_count",
          "label": "Star count",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "rating_text",
          "label": "Rating text",
          "default": "4.8/5 customer rating"
        }
      ]
    },
    {
      "type": "reviews",
      "name": "Reviews",
      "settings": [
        {
          "type": "text",
          "id": "reviews_text",
          "label": "Reviews text",
          "default": "Based on verified reviews"
        },
        {
          "type": "url",
          "id": "reviews_link",
          "label": "Reviews link"
        }
      ]
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_compare_price",
          "label": "Show compare-at price",
          "default": true
        },
        {
          "type": "text",
          "id": "sale_badge",
          "label": "Sale badge",
          "default": "Sale"
        }
      ]
    },
    {
      "type": "variant_picker",
      "name": "Variant picker",
      "limit": 1,
      "settings": []
    },
    {
      "type": "bullet",
      "name": "Bullet point",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Add a key product benefit"
        }
      ]
    },
    {
      "type": "quantity_selector",
      "name": "Quantity selector",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Quantity"
        },
        {
          "type": "range",
          "id": "default_quantity",
          "label": "Default quantity",
          "min": 1,
          "max": 10,
          "step": 1,
          "default": 1
        }
      ]
    },
    {
      "type": "add_to_cart",
      "name": "Add to cart",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Add to cart"
        },
        {
          "type": "text",
          "id": "sold_out_text",
          "label": "Sold out text",
          "default": "Sold out"
        }
      ]
    },
    {
      "type": "trust_item",
      "name": "Trust element",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "shield",
          "options": [
            {
              "value": "shield",
              "label": "Shield"
            },
            {
              "value": "truck",
              "label": "Truck"
            },
            {
              "value": "leaf",
              "label": "Leaf"
            },
            {
              "value": "heart",
              "label": "Heart"
            },
            {
              "value": "sparkle",
              "label": "Sparkle"
            },
            {
              "value": "clock",
              "label": "Clock"
            },
            {
              "value": "check",
              "label": "Check"
            }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Trusted quality"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Small text",
          "default": "Add delivery, guarantee, ingredients, or safety information."
        }
      ]
    },
    {
      "type": "collapsible",
      "name": "Collapsible tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab title",
          "default": "How to use"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Tab content",
          "default": "<p>Add instructions, description, ingredients, benefits, or care details here.</p>"
        }
      ]
    },
    {
      "type": "video_carousel",
      "name": "Video carousel",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "See it in action"
        },
        {
          "type": "video",
          "id": "video_1",
          "label": "Video 1"
        },
        {
          "type": "video",
          "id": "video_2",
          "label": "Video 2"
        },
        {
          "type": "video",
          "id": "video_3",
          "label": "Video 3"
        }
      ]
    }
  ],
  "max_blocks": 40,
  "presets": [
    {
      "name": "Featured product builder",
      "blocks": [
        {
          "type": "title"
        },
        {
          "type": "rating"
        },
        {
          "type": "reviews"
        },
        {
          "type": "price"
        },
        {
          "type": "variant_picker"
        },
        {
          "type": "bullet"
        },
        {
          "type": "bullet"
        },
        {
          "type": "bullet"
        },
        {
          "type": "quantity_selector"
        },
        {
          "type": "add_to_cart"
        },
        {
          "type": "trust_item"
        },
        {
          "type": "collapsible"
        }
      ]
    }
  ]
}
{% endschema %}
