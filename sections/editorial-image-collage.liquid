{{ 'editorial-image-collage.css' | asset_url | stylesheet_tag }}

<section
  class="editorial-image-collage editorial-image-collage--{{ section.id }}"
  data-animate="{{ section.settings.enable_animation }}"
  data-match-text-height="{{ section.settings.match_text_height }}"
  style="
    --eic-bg: {{ section.settings.section_background }};
    --eic-text: {{ section.settings.text_color }};
    --eic-muted: {{ section.settings.muted_text_color }};
    --eic-eyebrow: {{ section.settings.eyebrow_color }};
    --eic-accent: {{ section.settings.accent_color }};
    --eic-icon-bg: {{ section.settings.icon_background }};
    --eic-icon-text: {{ section.settings.icon_text_color }};
    --eic-image-bg: {{ section.settings.image_background }};
    --eic-radius: {{ section.settings.image_radius }}px;
    --eic-gap: {{ section.settings.image_gap }}px;
    --eic-text-padding-left: {{ section.settings.text_padding_left }}%;
    --eic-image-padding-right: {{ section.settings.image_padding_right }}%;
    --eic-stack-width: {{ section.settings.stack_column_width }}%;
    --eic-large-width: {{ 100 | minus: section.settings.stack_column_width }}%;
    --eic-desktop-height: {{ section.settings.desktop_image_height }}px;
    --eic-mobile-height: {{ section.settings.mobile_image_height }}px;
    --eic-top-fit: {{ section.settings.top_image_fit }};
    --eic-bottom-fit: {{ section.settings.bottom_image_fit }};
    --eic-large-fit: {{ section.settings.large_image_fit }};
    --eic-top-position: {{ section.settings.top_image_position }};
    --eic-bottom-position: {{ section.settings.bottom_image_position }};
    --eic-large-position: {{ section.settings.large_image_position }};
  "
>
  <div class="editorial-image-collage__container">
    <div class="editorial-image-collage__text">
      <div class="editorial-image-collage__text-inner">
        {% if section.settings.eyebrow != blank %}
          <span class="editorial-image-collage__eyebrow">
            {{ section.settings.eyebrow }}
          </span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="editorial-image-collage__heading">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <div class="editorial-image-collage__subheading">
            {{ section.settings.subheading }}
          </div>
        {% endif %}

        {% if section.settings.show_divider %}
          <div class="editorial-image-collage__divider"></div>
        {% endif %}

        {% if section.settings.body_text != blank %}
          <div class="editorial-image-collage__body">
            {{ section.settings.body_text }}
          </div>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="editorial-image-collage__features">
            {% for block in section.blocks %}
              {% if block.type == 'feature' and block.settings.text != blank %}
                <div class="editorial-image-collage__feature" {{ block.shopify_attributes }}>
                  <span class="editorial-image-collage__feature-icon" aria-hidden="true">
                    {{ section.settings.feature_icon }}
                  </span>
                  <span>{{ block.settings.text }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        {% if section.settings.cta_text != blank and section.settings.cta_link != blank %}
          <a href="{{ section.settings.cta_link }}" class="editorial-image-collage__link">
            {{ section.settings.cta_text }}

            {% if section.settings.show_cta_arrow %}
              <span class="editorial-image-collage__link-arrow" aria-hidden="true">→</span>
            {% endif %}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="editorial-image-collage__media">
      <div class="editorial-image-collage__stack">
        <div class="editorial-image-collage__stack-item">
          {% if section.settings.top_image != blank %}
            {{
              section.settings.top_image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                alt: section.settings.top_image_alt,
                class: 'editorial-image-collage__image editorial-image-collage__image--top'
            }}
          {% else %}
            <div class="editorial-image-collage__placeholder">Add top image</div>
          {% endif %}
        </div>

        <div class="editorial-image-collage__stack-item">
          {% if section.settings.bottom_image != blank %}
            {{
              section.settings.bottom_image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                alt: section.settings.bottom_image_alt,
                class: 'editorial-image-collage__image editorial-image-collage__image--bottom'
            }}
          {% else %}
            <div class="editorial-image-collage__placeholder">Add bottom image</div>
          {% endif %}
        </div>
      </div>

      <div class="editorial-image-collage__large">
        {% if section.settings.large_image != blank %}
          {{
            section.settings.large_image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              alt: section.settings.large_image_alt,
              class: 'editorial-image-collage__image editorial-image-collage__image--large'
          }}
        {% else %}
          <div class="editorial-image-collage__placeholder">Add large image</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script src="{{ 'editorial-image-collage.js' | asset_url }}" defer></script>

