{{ 'device-preview-hero-slider.css' | asset_url | stylesheet_tag }}

<section
  class="feature-spotlight feature-spotlight--{{ section.id }}"
  style="
    --fs-bg: {{ section.settings.section_bg }};
    --fs-card: {{ section.settings.card_bg }};
    --fs-text: {{ section.settings.text_color }};
    --fs-muted: {{ section.settings.muted_color }};
    --fs-accent: {{ section.settings.accent_color }};
    --fs-button-bg: {{ section.settings.button_bg }};
    --fs-button-text: {{ section.settings.button_text_color }};
    --fs-button-alt-bg: {{ section.settings.secondary_button_bg }};
    --fs-button-alt-text: {{ section.settings.secondary_button_text_color }};
    --fs-radius: {{ section.settings.card_radius }}px;
    --fs-image-radius: {{ section.settings.image_radius }}px;
    --fs-top: {{ section.settings.padding_top }}px;
    --fs-bottom: {{ section.settings.padding_bottom }}px;
    --fs-image-position: {{ section.settings.image_position }};
  "
>
  <div class="feature-spotlight__wrap page-width">
    <div class="feature-spotlight__grid">
      <div class="feature-spotlight__content">
        {% if section.settings.badge_text != blank %}
          <div class="feature-spotlight__badge">{{ section.settings.badge_text }}</div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="feature-spotlight__heading">{{ section.settings.heading | newline_to_br }}</h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <div class="feature-spotlight__subheading">{{ section.settings.subheading }}</div>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="feature-spotlight__features">
            {% for block in section.blocks %}
              {% if block.type == 'feature' and block.settings.text != blank %}
                <div class="feature-spotlight__feature" {{ block.shopify_attributes }}>
                  <span class="feature-spotlight__feature-icon">{{ section.settings.feature_icon }}</span>
                  <span>{{ block.settings.text }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        <div class="feature-spotlight__actions">
          {% if section.settings.primary_button_text != blank and section.settings.primary_button_link != blank %}
            <a href="{{ section.settings.primary_button_link }}" class="feature-spotlight__button feature-spotlight__button--primary">
              {{ section.settings.primary_button_text }}
            </a>
          {% endif %}

          {% if section.settings.secondary_button_text != blank and section.settings.secondary_button_link != blank %}
            <a href="{{ section.settings.secondary_button_link }}" class="feature-spotlight__button feature-spotlight__button--secondary">
              {{ section.settings.secondary_button_text }}
            </a>
          {% endif %}
        </div>

        {% if section.settings.note_text != blank %}
          <div class="feature-spotlight__note">{{ section.settings.note_text }}</div>
        {% endif %}
      </div>

      <div class="feature-spotlight__media">
        {% if section.settings.hero_image != blank %}
          {{
            section.settings.hero_image
            | image_url: width: 1800
            | image_tag:
              loading: 'lazy',
              widths: '480, 720, 960, 1200, 1600, 1800',
              class: 'feature-spotlight__image',
              alt: section.settings.hero_image_alt
          }}
        {% else %}
          <div class="feature-spotlight__placeholder">Add hero image</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature spotlight hero",
  "tag": "section",
  "class": "section section-feature-spotlight",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "NOW ON SALE"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Reduce stress.\nSleep peacefully.\nCarry peace."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A cleaner, sharper hero section with one image only and a strong conversion-focused layout."
    },
    {
      "type": "text",
      "id": "note_text",
      "label": "Small note",
      "default": "30-Day Money-Back Guarantee"
    },
    {
      "type": "text",
      "id": "feature_icon",
      "label": "Feature icon",
      "default": "✦"
    },
    {
      "type": "paragraph",
      "content": "Add button links below or the buttons will stay hidden."
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary button text",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Hero image alt text",
      "default": "Hero image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "default": "center center",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ]
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#eef2f7"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Content background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text color",
      "default": "#5f6368"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#5e6ad2"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Primary button background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Primary button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_button_bg",
      "label": "Secondary button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_button_text_color",
      "label": "Secondary button text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Content radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Feature text",
          "default": "Balance nervous system"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Feature spotlight hero",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}
