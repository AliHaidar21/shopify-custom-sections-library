{{ 'perfume-product-hero.css' | asset_url | stylesheet_tag }}

<section
  class="product-spotlight product-spotlight--{{ section.id }}"
  style="
    --ps-bg: {{ section.settings.section_bg }};
    --ps-overlay: {{ section.settings.overlay_color }};
    --ps-card: {{ section.settings.card_bg }};
    --ps-text: {{ section.settings.text_color }};
    --ps-muted: {{ section.settings.muted_color }};
    --ps-accent: {{ section.settings.accent_color }};
    --ps-button-bg: {{ section.settings.button_bg }};
    --ps-button-text: {{ section.settings.button_text_color }};
    --ps-radius: {{ section.settings.card_radius }}px;
    --ps-media-radius: {{ section.settings.media_radius }}px;
    --ps-top: {{ section.settings.padding_top }}px;
    --ps-bottom: {{ section.settings.padding_bottom }}px;
    --ps-product-position: {{ section.settings.product_image_position }};
  "
>
  {% if section.settings.background_image != blank %}
    <div class="product-spotlight__background">
      {{
        section.settings.background_image
        | image_url: width: 2200
        | image_tag:
          loading: 'lazy',
          widths: '480, 720, 960, 1200, 1600, 2000, 2200',
          class: 'product-spotlight__background-image',
          alt: section.settings.background_alt
      }}
    </div>
  {% endif %}

  <div class="product-spotlight__overlay"></div>

  <div class="product-spotlight__wrap page-width">
    <div class="product-spotlight__card">
      {% if section.settings.eyebrow != blank %}
        <div class="product-spotlight__eyebrow">{{ section.settings.eyebrow }}</div>
      {% endif %}

      {% if section.settings.accent_heading != blank %}
        <div class="product-spotlight__accent-heading">{{ section.settings.accent_heading }}</div>
      {% endif %}

      {% if section.settings.main_heading != blank %}
        <h2 class="product-spotlight__heading">{{ section.settings.main_heading | newline_to_br }}</h2>
      {% endif %}

      <div class="product-spotlight__media">
        {% if section.settings.product_image != blank %}
          {{
            section.settings.product_image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              widths: '320, 480, 720, 960, 1200',
              class: 'product-spotlight__product-image',
              alt: section.settings.product_alt
          }}
        {% else %}
          <div class="product-spotlight__placeholder">Add product image</div>
        {% endif %}
      </div>

      {% if section.settings.rating_text != blank %}
        <div class="product-spotlight__rating-text">{{ section.settings.rating_text }}</div>
      {% endif %}

      {% if section.settings.rating_stars != blank %}
        <div class="product-spotlight__stars">{{ section.settings.rating_stars }}</div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="product-spotlight__benefits">
          {% for block in section.blocks %}
            {% if block.type == 'benefit' and block.settings.text != blank %}
              <div class="product-spotlight__benefit" {{ block.shopify_attributes }}>
                <span class="product-spotlight__benefit-icon">{{ section.settings.benefit_icon }}</span>
                <span>{{ block.settings.text }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.button_text != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="product-spotlight__button">
          {{ section.settings.button_text }}
        </a>
      {% endif %}

      {% if section.settings.guarantee_text != blank %}
        <div class="product-spotlight__guarantee">{{ section.settings.guarantee_text }}</div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product spotlight hero",
  "tag": "section",
  "class": "section section-product-spotlight",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Small top text",
      "default": "Customer favorite"
    },
    {
      "type": "text",
      "id": "accent_heading",
      "label": "Italic heading line",
      "default": "The Essence of"
    },
    {
      "type": "textarea",
      "id": "main_heading",
      "label": "Main heading",
      "default": "Irresistible Presence"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "background_alt",
      "label": "Background alt text",
      "default": "Background image"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "product_alt",
      "label": "Product image alt text",
      "default": "Product image"
    },
    {
      "type": "select",
      "id": "product_image_position",
      "label": "Product image position",
      "default": "center center",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ]
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating text",
      "default": "4.7/5.0 | 2X Sell-out Viral Product"
    },
    {
      "type": "text",
      "id": "rating_stars",
      "label": "Stars",
      "default": "★★★★★"
    },
    {
      "type": "text",
      "id": "benefit_icon",
      "label": "Benefit icon",
      "default": "✦"
    },
    {
      "type": "paragraph",
      "content": "Add a button link below or the button will stay hidden."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Unlock your signature scent →"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "30-Day Money-back Guarantee"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Fallback background",
      "default": "#f4eefc"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1333"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text color",
      "default": "#6d6388"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#6d3fd1"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#d8b6ff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#23153f"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "media_radius",
      "label": "Image radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Benefit text",
          "default": "Boost your social battery and magnetic pull"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Product spotlight hero",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "benefit" }
      ]
    }
  ]
}
{% endschema %}
